<Window x:Class="Kleptos.MainWindow"
        xmlns:wc="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kleptos"
        mc:Ignorable="d"
        Title="Kleptos" Height="600" Width="1000" MinHeight="600" MinWidth="1000" WindowStartupLocation="CenterScreen" WindowStyle="None"
        Background="Transparent" AllowsTransparency="True" ResizeMode="CanResize">
    <WindowChrome.WindowChrome>
        <wc:WindowChrome CaptionHeight="0"
                     ResizeBorderThickness="6"
                     GlassFrameThickness="0"
                     UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <!-- Color Definitions -->
        <SolidColorBrush x:Key="AccentColor" Color="#ff3c3c"/>
        <SolidColorBrush x:Key="AccentColorHover" Color="#ff5555"/>
        <SolidColorBrush x:Key="AccentColorPressed" Color="#cc3030"/>
        <SolidColorBrush x:Key="BackgroundDark" Color="#191919"/>
        <SolidColorBrush x:Key="BackgroundCard" Color="#1e1e1e"/>
        <SolidColorBrush x:Key="BackgroundInput" Color="#252525"/>
        <SolidColorBrush x:Key="BackgroundHover" Color="#2a2a2a"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e1e1e1"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#888888"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#333333"/>
        <SolidColorBrush x:Key="ScrollBarThumb" Color="#3a3a3a"/>
        <SolidColorBrush x:Key="ScrollBarThumbHover" Color="#505050"/>
        <SolidColorBrush x:Key="ScrollBarThumbPressed" Color="#606060"/>

        <!-- Scrollbar Thumb (vertical) -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="thumbBorder" CornerRadius="3" Background="{StaticResource ScrollBarThumb}" Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource ScrollBarThumbHover}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource ScrollBarThumbPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar Thumb (horizontal) -->
        <Style x:Key="ScrollBarThumbHorizontalStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="thumbBorder" CornerRadius="3" Background="{StaticResource ScrollBarThumb}" Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource ScrollBarThumbHover}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource ScrollBarThumbPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical ScrollBar -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid>
                            <Border CornerRadius="4" Background="Transparent"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" MinHeight="20"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="MinHeight" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid>
                                    <Border CornerRadius="4" Background="Transparent"/>
                                    <Track x:Name="PART_Track">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbHorizontalStyle}" MinWidth="20"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern URL Input TextBox -->
        <Style TargetType="{x:Type TextBox}" x:Key="URLInputTextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border" CornerRadius="8" Background="{StaticResource BackgroundInput}" BorderThickness="2" BorderBrush="Transparent">
                            <ScrollViewer Margin="12,0" x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern File Name TextBox -->
        <Style TargetType="{x:Type TextBox}" x:Key="FileNameTextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border" CornerRadius="6" Background="{StaticResource BackgroundInput}" BorderThickness="1" BorderBrush="{StaticResource BorderSubtle}">
                            <ScrollViewer Margin="8,0" x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern File Output TextBox -->
        <Style TargetType="{x:Type TextBox}" x:Key="FileOutputTextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border" CornerRadius="8" Background="{StaticResource BackgroundInput}" BorderThickness="2" BorderBrush="Transparent">
                            <ScrollViewer Margin="12,0" x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Console Output TextBox -->
        <Style TargetType="{x:Type TextBox}" x:Key="ConsoleOutputTextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" Background="Transparent">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Console Output ScrollViewer -->
        <Style TargetType="{x:Type ScrollViewer}" x:Key="ConsoleOutputScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Border CornerRadius="12" Background="{StaticResource BackgroundCard}" BorderThickness="0" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ScrollContentPresenter Grid.Column="0"/>
                                <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                                           Value="{TemplateBinding VerticalOffset}"
                                           Maximum="{TemplateBinding ScrollableHeight}"
                                           ViewportSize="{TemplateBinding ViewportHeight}"
                                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                           Margin="4,0,0,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Download Button -->
        <Style TargetType="{x:Type Button}" x:Key="DownloadButton">
            <Setter Property="Background" Value="{StaticResource AccentColor}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="{StaticResource AccentColorHover}" TargetName="Border" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColorPressed}" TargetName="Border" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button (File Path, Cookies, Copy) -->
        <Style TargetType="{x:Type Button}" x:Key="FilePathButton">
            <Setter Property="Background" Value="{StaticResource BackgroundInput}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="{StaticResource BackgroundHover}" TargetName="Border" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}" TargetName="Border" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Get Cookies Button -->
        <Style TargetType="{x:Type Button}" x:Key="GetCookiesButton">
            <Setter Property="Background" Value="{StaticResource BackgroundInput}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="{StaticResource BackgroundHover}" TargetName="Border" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}" TargetName="Border" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Update Button -->
        <Style TargetType="{x:Type Button}" x:Key="UpdateButton">
            <Setter Property="Background" Value="#2d8a4e" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="#3da55d" TargetName="Border" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#248046" TargetName="Border" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Button (Minimize) -->
        <Style TargetType="{x:Type Button}" x:Key="WindowButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="{StaticResource BackgroundHover}" TargetName="Border" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource BackgroundInput}" TargetName="Border" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Window Button -->
        <Style TargetType="{x:Type Button}" x:Key="CloseWindowButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="{StaticResource AccentColor}" TargetName="Border" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColorPressed}" TargetName="Border" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBox -->
        <Style TargetType="{x:Type ComboBox}" x:Key="RoundedComboBox">
            <Setter Property="Background" Value="{StaticResource BackgroundInput}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        BorderThickness="1"
                        BorderBrush="{StaticResource BorderSubtle}">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                <ToggleButton x:Name="ToggleButton"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Width="130"
                                     Height="20"
                                     Background="Transparent"
                                     BorderBrush="Transparent"
                                     IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                     ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="0">
                                                <ContentPresenter Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                        Fill="{StaticResource TextSecondary}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </ToggleButton>
                                <Popup x:Name="Popup"
                                Placement="Bottom"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Fade">
                                    <Border Background="{StaticResource BackgroundCard}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="4"
                                    Margin="0,4,0,0"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer>
                                            <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBox Item -->
        <Style TargetType="{x:Type ComboBoxItem}" x:Key="RoundedComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        Padding="8,6"
                        Margin="0,1">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill Toggle Button (RadioButton) -->
        <Style TargetType="{x:Type RadioButton}" x:Key="PillToggleButton">
            <Setter Property="Background" Value="{StaticResource BackgroundInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontFamily" Value="{StaticResource JetBrainsReg}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="16,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundHover}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColorHover}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern CheckBox -->
        <Style TargetType="{x:Type CheckBox}" x:Key="ModernCheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Border x:Name="Border"
                                Width="20" Height="20"
                                CornerRadius="4"
                                Background="{StaticResource BackgroundInput}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="2">
                            <Path x:Name="CheckMark"
                                  Data="M 3 8 L 7 12 L 15 4"
                                  Stroke="{StaticResource TextPrimary}"
                                  StrokeThickness="2"
                                  Visibility="Collapsed"
                                  Margin="1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" Background="{StaticResource BackgroundDark}">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Background="{StaticResource BackgroundDark}" CornerRadius="16,16,0,0">
                <Grid Height="48" VerticalAlignment="Top" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Version Text -->
                    <TextBlock Grid.Column="0" x:Name="txtKleptosVersion" FontFamily="{StaticResource JetBrainsReg}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0,0,0"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Text="v1.1.0"/>

                    <!-- Title -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="{StaticResource JetBrainsReg}" Foreground="{StaticResource AccentColor}" FontSize="20" FontWeight="Bold" Text="Kleptos"/>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Style="{StaticResource UpdateButton}" x:Name="UpdateButton" Height="28" Margin="0,0,8,0" Click="Update_Click">
                            <TextBlock Text="Update Available" Foreground="White" FontFamily="{StaticResource JetBrainsReg}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Margin="12,0"/>
                        </Button>
                        <Button Style="{StaticResource WindowButton}" Width="32" Height="32" Margin="0,0,4,0" Click="MinimizeButton_Click">
                            <Path Data="M 4 10 L 12 10" Stroke="{StaticResource TextSecondary}" StrokeThickness="2"/>
                        </Button>
                        <Button Style="{StaticResource CloseWindowButton}" Width="32" Height="32" Click="CloseButton_Click">
                            <Path Data="M 4 4 L 12 12 M 12 4 L 4 12" Stroke="{StaticResource TextPrimary}" StrokeThickness="2"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Background="{StaticResource BackgroundDark}" Grid.Row="1" Margin="20,0,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.3*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel -->
                <Grid Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- URL Input Section -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource JetBrainsReg}" FontSize="13" FontWeight="SemiBold" Margin="4,0,0,8">URL</TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtURL" Style="{StaticResource URLInputTextBox}" FontFamily="{StaticResource JetBrainsReg}"
                                     SelectionBrush="{StaticResource AccentColor}" CaretBrush="{StaticResource TextSecondary}"
                                     Height="44" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Click="Download_Click" Style="{StaticResource DownloadButton}" FontFamily="{StaticResource JetBrainsReg}"
                                    Foreground="White" FontWeight="SemiBold" Height="44" Margin="10,0,0,0" FontSize="13">Download</Button>
                        </Grid>
                    </StackPanel>

                    <!-- File Output Section -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <TextBlock Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource JetBrainsReg}" FontSize="13" FontWeight="SemiBold" Margin="4,0,0,8">Output Location</TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtFileOutput" Style="{StaticResource FileOutputTextBox}" FontFamily="{StaticResource JetBrainsReg}"
                                     SelectionBrush="{StaticResource AccentColor}" CaretBrush="{StaticResource TextSecondary}"
                                     Height="44" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Click="FileOutput_Click" Style="{StaticResource FilePathButton}" FontFamily="{StaticResource JetBrainsReg}"
                                    Foreground="{StaticResource TextPrimary}" Width="44" Height="44" Margin="10,0,0,0" FontSize="16">
                                <Path Data="M 2 14 L 2 4 C 2 3 3 2 4 2 L 10 2 L 12 5 L 18 5 C 19 5 20 6 20 7 L 20 14 C 20 15 19 16 18 16 L 4 16 C 3 16 2 15 2 14 Z"
                                      Stroke="{StaticResource TextPrimary}" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="16"/>
                            </Button>
                            <Button Grid.Column="2" Click="FileCookies_Click" Style="{StaticResource FilePathButton}" FontFamily="{StaticResource JetBrainsReg}"
                                    Foreground="{StaticResource TextPrimary}" Height="44" Margin="8,0,0,0" FontSize="12" Padding="16,0">Cookies</Button>
                        </Grid>
                    </StackPanel>

                    <!-- Output Section with Pill Toggle -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Pill Toggle Bar -->
                        <Border Grid.Row="0" Background="{StaticResource BackgroundCard}" CornerRadius="10" Padding="4" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="rbShowInfo" Content="Show Info" Style="{StaticResource PillToggleButton}"
                                             GroupName="OutputToggle" IsChecked="True" Checked="OutputToggle_Checked"/>
                                <RadioButton x:Name="rbConsole" Content="Console" Style="{StaticResource PillToggleButton}"
                                             GroupName="OutputToggle" Margin="4,0,0,0" Checked="OutputToggle_Checked"/>
                                <RadioButton x:Name="rbSegments" Content="Segments" Style="{StaticResource PillToggleButton}"
                                             GroupName="OutputToggle" Margin="4,0,0,0" Checked="OutputToggle_Checked"/>
                            </StackPanel>
                        </Border>

                        <!-- Show Info Panel -->
                        <Border x:Name="pnlShowInfo" Grid.Row="1" CornerRadius="12" Background="{StaticResource BackgroundCard}" Padding="16" Visibility="Visible">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Progress Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="Progress" Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource JetBrainsReg}"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtProgressPercent" Text="0%" Foreground="{StaticResource AccentColor}" FontFamily="{StaticResource JetBrainsReg}"
                                               FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Progress Bar -->
                                <Border Grid.Row="1" Height="8" CornerRadius="4" Background="{StaticResource BackgroundInput}" Margin="0,0,0,10">
                                    <Border x:Name="progressBarFill" Height="8" CornerRadius="4" Background="{StaticResource AccentColor}"
                                            HorizontalAlignment="Left" Width="0"/>
                                </Border>

                                <!-- Current Status -->
                                <TextBlock x:Name="txtCurrentStatus" Grid.Row="2" Text="Waiting to start..."
                                           Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource JetBrainsReg}"
                                           FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,0,0,12"/>

                                <!-- Stats Area -->
                                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="pnlStats"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Console Panel (existing, now toggled) -->
                        <Grid x:Name="pnlConsole" Grid.Row="1" Visibility="Collapsed">
                            <ScrollViewer x:Name="scrollViewer" Style="{StaticResource ConsoleOutputScrollViewer}" FontSize="11" VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="txtOutput" Style="{StaticResource ConsoleOutputTextBox}" FontFamily="{StaticResource JetBrainsReg}"
                                         SelectionBrush="{StaticResource AccentColor}" Foreground="{StaticResource AccentColor}"
                                         IsReadOnly="True" TextWrapping="Wrap"/>
                            </ScrollViewer>
                            <Button Click="CopyLogs_Click" Style="{StaticResource FilePathButton}" FontFamily="{StaticResource JetBrainsReg}"
                                    Foreground="{StaticResource TextPrimary}" Width="36" Height="36" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8">
                                <Path Data="M 4 2 L 12 2 L 12 12 L 4 12 Z M 6 12 L 6 14 L 14 14 L 14 4 L 12 4"
                                      Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5" Fill="Transparent" Width="14" Height="14"/>
                            </Button>
                        </Grid>

                        <!-- Segments Panel -->
                        <Border x:Name="pnlSegmentsTab" Grid.Row="1" CornerRadius="12" Background="{StaticResource BackgroundCard}" Padding="16" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <!-- Thumbnail Preview -->
                                    <Border CornerRadius="8" Background="{StaticResource BackgroundInput}" Margin="0,0,0,10"
                                            MaxHeight="160" ClipToBounds="True">
                                        <Image x:Name="imgThumbnail" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <!-- Video Title -->
                                    <TextBlock x:Name="txtVideoTitle" Text="" Foreground="{StaticResource TextPrimary}"
                                               FontFamily="{StaticResource JetBrainsReg}" FontSize="12" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,0,8" Visibility="Collapsed"/>

                                    <!-- Duration Info Row -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="txtSegmentDuration" Text="Duration: --:--:--"
                                                   Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource JetBrainsReg}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                        <Button x:Name="btnFetchDuration" Grid.Column="1" Click="btnFetchDuration_Click"
                                                Style="{StaticResource FilePathButton}" FontFamily="{StaticResource JetBrainsReg}"
                                                Foreground="{StaticResource TextPrimary}" FontSize="11" Padding="10,4" Height="28">Fetch Info</Button>
                                    </Grid>

                                    <!-- Timeline Bar with Seek Preview -->
                                    <Grid x:Name="pnlTimeline" Height="16" Margin="0,0,0,10" Visibility="Collapsed" Cursor="Hand"
                                          MouseMove="Timeline_MouseMove" MouseLeave="Timeline_MouseLeave"
                                          MouseLeftButtonDown="Timeline_MouseLeftButtonDown" MouseRightButtonDown="Timeline_MouseRightButtonDown"
                                          Background="Transparent">
                                        <Border CornerRadius="4" Background="{StaticResource BackgroundInput}"/>
                                        <Canvas x:Name="cnvTimeline" ClipToBounds="True"/>
                                        <Popup x:Name="popSeekPreview" Placement="Relative" PlacementTarget="{Binding ElementName=pnlTimeline}"
                                               AllowsTransparency="True" IsHitTestVisible="False" VerticalOffset="-30" HorizontalOffset="0">
                                            <Border CornerRadius="4" Background="{StaticResource BackgroundCard}" BorderBrush="{StaticResource BorderSubtle}"
                                                    BorderThickness="1" Padding="6,3">
                                                <TextBlock x:Name="txtSeekTimestamp" Text="0:00" Foreground="{StaticResource TextPrimary}"
                                                           FontFamily="{StaticResource JetBrainsReg}" FontSize="11"/>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <!-- Segment Rows -->
                                    <StackPanel x:Name="pnlSegmentRows" Margin="0,0,0,6"/>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Right Panel (Settings) -->
                <Border Grid.Column="1" CornerRadius="12" Background="{StaticResource BackgroundCard}" Margin="10,0,0,0">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Settings Header -->
                        <TextBlock Grid.Row="0" Text="Settings" Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource JetBrainsReg}"
                                   FontSize="15" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- File Format -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" FontFamily="{StaticResource JetBrainsReg}" FontSize="12">Format</TextBlock>
                            <ComboBox x:Name="cmbFileFormats" Grid.Column="1" Style="{StaticResource RoundedComboBox}" FontFamily="{StaticResource JetBrainsReg}" Foreground="{StaticResource TextPrimary}" Height="32">
                                <ComboBoxItem Style="{StaticResource RoundedComboBoxItem}" FontFamily="{StaticResource JetBrainsReg}" IsSelected="True">default</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource RoundedComboBoxItem}" FontFamily="{StaticResource JetBrainsReg}">mp4</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource RoundedComboBoxItem}" FontFamily="{StaticResource JetBrainsReg}">mov</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource RoundedComboBoxItem}" FontFamily="{StaticResource JetBrainsReg}">flv</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource RoundedComboBoxItem}" FontFamily="{StaticResource JetBrainsReg}">webm</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource RoundedComboBoxItem}" FontFamily="{StaticResource JetBrainsReg}">m4a</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource RoundedComboBoxItem}" FontFamily="{StaticResource JetBrainsReg}">mp3</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource RoundedComboBoxItem}" FontFamily="{StaticResource JetBrainsReg}">wav</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource RoundedComboBoxItem}" FontFamily="{StaticResource JetBrainsReg}">3gp</ComboBoxItem>
                            </ComboBox>
                        </Grid>

                        <!-- File Name -->
                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" FontFamily="{StaticResource JetBrainsReg}" FontSize="12">File Name</TextBlock>
                            <TextBox x:Name="txtFileName" Grid.Column="1" Style="{StaticResource FileNameTextBox}" FontFamily="{StaticResource JetBrainsReg}"
                                     SelectionBrush="{StaticResource AccentColor}" CaretBrush="{StaticResource TextSecondary}"
                                     Height="32" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                        </Grid>

                        <!-- Thumbnail Only -->
                        <Grid Grid.Row="3" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" FontFamily="{StaticResource JetBrainsReg}" FontSize="12">Thumbnail Only</TextBlock>
                            <CheckBox x:Name="cbThumbnailOnly" Grid.Column="1" Style="{StaticResource ModernCheckBox}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Multi URLs Section -->
                        <Grid Grid.Row="4" Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource JetBrainsReg}" FontSize="12" Margin="0,0,0,8">Multiple URLs (one per line)</TextBlock>
                            <Border Grid.Row="1" CornerRadius="8" Background="{StaticResource BackgroundInput}" BorderThickness="1" BorderBrush="{StaticResource BorderSubtle}">
                                <TextBox x:Name="txtMultiUrls"
                                         FontFamily="{StaticResource JetBrainsReg}"
                                         SelectionBrush="{StaticResource AccentColor}"
                                         CaretBrush="{StaticResource TextSecondary}"
                                         Foreground="{StaticResource TextPrimary}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="10"
                                         FontSize="11"/>
                            </Border>
                        </Grid>

                        <!-- Multi Download Toggle -->
                        <Grid Grid.Row="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" FontFamily="{StaticResource JetBrainsReg}" FontSize="12">Enable Multi-Download</TextBlock>
                            <CheckBox x:Name="cbMultiDownload" Grid.Column="1" Style="{StaticResource ModernCheckBox}" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
